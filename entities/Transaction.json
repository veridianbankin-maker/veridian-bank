{
  "entity_name": "Transaction",
  "schema": {
    "type": "object",
    "properties": {
      "transaction_id": { "type": "string" },
      "customer_id": { "type": "string" },
      "account_number": { "type": "string" },
      "transaction_type": { "type": "string", "enum": ["Credit","Debit","Transfer","Bill Payment","EMI","Withdrawal","Deposit"] },
      "amount": { "type": "number" },
      "balance_after": { "type": "number" },
      "recipient_account": { "type": "string" },
      "recipient_name": { "type": "string" },
      "transfer_mode": { "type": "string", "enum": ["NEFT","RTGS","IMPS","UPI","NACH","Internal","Cash"] },
      "description": { "type": "string" },
      "reference_number": { "type": "string" },
      "status": { "type": "string", "enum": ["Pending","Success","Failed","Reversed"] },
      "initiated_from": { "type": "string", "enum": ["Mobile","Web","Branch","ATM","CSP"] },
      "processing_fee": { "type": "number" }
    },
    "required": ["transaction_id", "amount"]
  },
  "email_policy": {
    "send_customer_email": true,
    "triggers": ["Withdrawal", "Deposit", "Transfer"],
    "send_admin_email": false
  }
}
