{
  "entity": "Loan",
  "description": "Loan applications, approvals, and repayment tracking",
  "fields": {
    "loan_id": { "type": "string", "description": "Unique loan identifier" },
    "customer_id": { "type": "string", "description": "Applicant customer ID" },
    "account_number": { "type": "string", "description": "Linked account number" },
    "loan_type": { "type": "string", "enum": ["Home Loan", "Personal Loan", "Car Loan", "Education Loan", "Business Loan", "Gold Loan", "Agri Loan"], "description": "Type of loan" },
    "loan_amount": { "type": "number", "description": "Applied loan amount (INR)" },
    "approved_amount": { "type": "number", "description": "Sanctioned loan amount (INR)" },
    "interest_rate": { "type": "number", "description": "Annual interest rate (%)" },
    "tenure_months": { "type": "integer", "description": "Repayment tenure in months" },
    "emi_amount": { "type": "number", "description": "Monthly EMI amount (INR)" },
    "outstanding_amount": { "type": "number", "description": "Remaining balance (INR)" },
    "status": { "type": "string", "enum": ["Applied", "Under Review", "Approved", "Rejected", "Disbursed", "Active", "Closed", "NPA"], "description": "Loan status" },
    "application_date": { "type": "string", "format": "date", "description": "Date of application" },
    "disbursement_date": { "type": "string", "format": "date", "description": "Date of disbursement" }
  },
  "auto_fields": ["id", "created_date", "updated_date", "created_by"]
}
